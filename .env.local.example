DATABASE_URL='postgresql://neondb_owner:npg_xNSQ16qbyOUR@ep-long-art-ad35mxxz-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require' node -e 'const {PrismaClient}=require("@prisma/client"); const bcrypt=require("bcryptjs"); (async()=>{const db=new PrismaClient(); const hash=await bcrypt.hash("admin@123",10); await db.user.upsert({where:{username:"admin"}, update:{passwordHash:hash, role:"ADMIN", isActive:true}, create:{username:"admin", passwordHash:hash, role:"ADMIN", isActive:true}}); console.log("admin ready"); await db.$disconnect();})().catch(e=>{console.error(e); process.exit(1);});'